{
  "name": "shield-desktop",
  "version": "1.0.23",
  "description": "Desktop shell for Shield",
  "main": "main.cjs",
  "private": true,
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis --publish never -c.win.signAndEditExecutable=false",
    "dist:unsigned": "electron-builder --win nsis --publish never -c.win.signAndEditExecutable=false",
    "predist:production": "node build/validate-production-config.cjs",
    "dist:production": "electron-builder --win nsis -c.publish.provider=generic -c.publish.url=${env.SHIELD_UPDATE_URL}",
    "dist:portable": "electron-builder --win portable --publish never -c.win.signAndEditExecutable=false",
    "predist:portable:production": "node build/validate-production-config.cjs",
    "dist:portable:production": "electron-builder --win portable -c.publish.provider=generic -c.publish.url=${env.SHIELD_UPDATE_URL}"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "rcedit": "^5.0.2"
  },
  "build": {
    "icon": "build/icon.ico",
    "afterPack": "build/after-pack.cjs",
    "appId": "com.shield.desktop",
    "productName": "Shield",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "build/icon.png",
      "build/icon.ico",
      "config*.json",
      "README.md"
    ],
    "win": {
      "signAndEditExecutable": true,
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Shield-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Shield",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
