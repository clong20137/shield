DB_HOST=your-database-host
DB_USER=shield_app
DB_PASSWORD=replace_with_a_strong_database_password
DB_NAME=shield
DB_PORT=3306
PORT=5000
NODE_ENV=production
APP_BASE_URL=https://your-agency-blueline-command.example.gov
API_BASE_URL=https://your-agency-blueline-command.example.gov
ALLOWED_ORIGINS=https://your-agency-blueline-command.example.gov
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=passwordresetshield@outlook.com
SMTP_PASSWORD=replace_with_outlook_password_or_app_password
SMTP_FROM=passwordresetshield@outlook.com
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_HELO=shield.local
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
TRUST_PROXY=true
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=1200
API_REQUEST_TIMEOUT_MS=30000
ALLOW_CONSOLE_RESET_LINKS=false
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://your-agency-blueline-command.example.gov/api/auth/microsoft/callback
SSO_STATE_SECRET=replace_with_a_unique_random_secret_at_least_32_characters
DATA_ENCRYPTION_KEY=replace_with_a_32_byte_base64_or_64_character_hex_key
DATA_INDEX_KEY=replace_with_a_separate_32_byte_base64_or_64_character_hex_key
